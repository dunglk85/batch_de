{
  "title": "PostgreSQL – DWH Stack A",
  "uid": "dwh_postgresql",
  "tags": ["dataops", "dwh", "postgresql"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "pg_stat_activity_count", "legendFormat": "Total Connections", "interval": "", "exemplar": true
      }, {
        "expr": "pg_stat_database_numbackends", "legendFormat": "Backends", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 2,
      "title": "Database Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "pg_database_size_bytes", "legendFormat": "Size", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 3,
      "title": "Wal Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "pg_wal_size_bytes", "legendFormat": "WAL Size", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 4,
      "title": "Deadlocks, Commits & Rollbacks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "rate(pg_stat_database_deadlocks[5m])", "legendFormat": "Deadlocks/s", "interval": "", "exemplar": true
      }, {
        "expr": "rate(pg_stat_database_xact_rollback[5m])", "legendFormat": "Rollbacks/s", "interval": "", "exemplar": true
      }, {
        "expr": "rate(pg_stat_database_xact_commit[5m])", "legendFormat": "Commits/s", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 5,
      "title": "Tuples Written per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "rate(pg_stat_database_tup_inserted[5m])", "legendFormat": "Inserts/s", "interval": "", "exemplar": true
      }, {
        "expr": "rate(pg_stat_database_tup_updated[5m])", "legendFormat": "Updates/s", "interval": "", "exemplar": true
      }, {
        "expr": "rate(pg_stat_database_tup_deleted[5m])", "legendFormat": "Deletes/s", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 6,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "rate(pg_stat_database_blks_hit[5m]) / (rate(pg_stat_database_blks_hit[5m]) + rate(pg_stat_database_blks_read[5m])) * 100",
        "legendFormat": "Cache Hit %", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 7,
      "title": "Table Index & Heap I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "rate(pg_statio_user_tables_heap_blocks_read[5m]) + rate(pg_statio_user_tables_idx_blocks_read[5m])",
        "legendFormat": "Blocks Read/s", "interval": "", "exemplar": true
      }, {
        "expr": "rate(pg_statio_user_tables_heap_blocks_hit[5m]) + rate(pg_statio_user_tables_idx_blocks_hit[5m])",
        "legendFormat": "Blocks Hit/s", "interval": "", "exemplar": true
      }]
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
