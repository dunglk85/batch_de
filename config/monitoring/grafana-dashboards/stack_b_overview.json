{
  "title": "Stack B – Lakehouse Overview",
  "uid": "stack_b_overview",
  "tags": ["dataops", "lakehouse", "stack-b", "spark", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 5,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Alive Workers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "spark_master_aliveWorkers",
        "legendFormat": "Alive", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 2,
      "title": "Cores (Used / Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 2 },
            { "color": "red", "value": 3 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "spark_worker_coresUsed",
        "legendFormat": "Used", "interval": "", "exemplar": true
      }, {
        "expr": "spark_worker_coresFree + spark_worker_coresUsed",
        "legendFormat": "Total", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 3,
      "title": "Memory (Used / Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1073741824 },
            { "color": "red", "value": 2147483648 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "spark_worker_memUsed_MB * 1048576",
        "legendFormat": "Used", "interval": "", "exemplar": true
      }, {
        "expr": "(spark_worker_memFree_MB + spark_worker_memUsed_MB) * 1048576",
        "legendFormat": "Total", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 4,
      "title": "Running Apps",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "spark_master_apps",
        "legendFormat": "Apps", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 5,
      "title": "Core Utilization",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "spark_worker_coresFree + spark_worker_coresUsed",
        "legendFormat": "Total", "interval": "", "exemplar": true
      }, {
        "expr": "spark_worker_coresUsed",
        "legendFormat": "Used", "interval": "", "exemplar": true
      }, {
        "expr": "spark_worker_coresFree",
        "legendFormat": "Free", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 6,
      "title": "Memory Utilization",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "(spark_worker_memFree_MB + spark_worker_memUsed_MB) * 1048576",
        "legendFormat": "Total", "interval": "", "exemplar": true
      }, {
        "expr": "spark_worker_memUsed_MB * 1048576",
        "legendFormat": "Used", "interval": "", "exemplar": true
      }, {
        "expr": "spark_worker_memFree_MB * 1048576",
        "legendFormat": "Free", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 7,
      "title": "Apps & Workers",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "spark_master_aliveWorkers",
        "legendFormat": "Alive Workers", "interval": "", "exemplar": true
      }, {
        "expr": "spark_master_apps",
        "legendFormat": "Running Apps", "interval": "", "exemplar": true
      }, {
        "expr": "spark_master_waitingApps",
        "legendFormat": "Waiting Apps", "interval": "", "exemplar": true
      }, {
        "expr": "spark_worker_executors",
        "legendFormat": "Executors", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 8,
      "title": "JVM – Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "java_lang_Memory_HeapMemoryUsage_used",
        "legendFormat": "{{instance}}", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 9,
      "title": "JVM – Non-Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "java_lang_Memory_NonHeapMemoryUsage_used",
        "legendFormat": "{{instance}}", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 10,
      "title": "JVM – GC Rate",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "rate(jvm_gc_collection_seconds_count[1m])",
        "legendFormat": "{{instance}} {{gc}}", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 11,
      "title": "Container CPU – Stack B",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "minVizWidth": 0, "minVizHeight": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 80 }
          ]},
          "custom": { "displayMode": "gradient" }
        }, "overrides": []
      },
      "targets": [{
        "expr": "topk(5, rate(container_cpu_usage_seconds_total{cpu=\"total\", id!=\"/\", id!=\"/docker\"}[1m]) * 100)",
        "legendFormat": "{{id}}", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 12,
      "title": "Container Memory – Stack B",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "minVizWidth": 0, "minVizHeight": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 524288000 },
            { "color": "red", "value": 1073741824 }
          ]},
          "custom": { "displayMode": "gradient" }
        }, "overrides": []
      },
      "targets": [{
        "expr": "topk(5, container_memory_working_set_bytes{id!=\"/\", id!=\"/docker\"})",
        "legendFormat": "{{id}}", "interval": "", "exemplar": true
      }]
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
