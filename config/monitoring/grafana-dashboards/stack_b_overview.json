    {
      "id": 4,
      "title": "Memory (Used / Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1073741824 },
            { "color": "red", "value": 2147483648 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "spark_Master_MemoryUsed_Value", "legendFormat": "Used", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 5,
      "title": "Applications Running",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "spark_Master_Apps_Value", "legendFormat": "Apps", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 6,
      "title": "Executors – Active Tasks",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "spark_Executor_ActiveTasks_Count", "legendFormat": "Active Tasks", "interval": "", "exemplar": true
      }, {
        "expr": "spark_Executor_CompletedTasks_Count", "legendFormat": "Completed Tasks", "interval": "", "exemplar": true
      }, {
        "expr": "spark_Executor_FailedTasks_Count", "legendFormat": "Failed Tasks", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 7,
      "title": "Executor Memory & Cores",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
