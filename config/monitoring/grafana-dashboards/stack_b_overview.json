{
  "title": "Stack B – Lakehouse Overview",
  "uid": "stack_b_overview",
  "tags": ["dataops", "lakehouse", "stack-b", "spark", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Alive Workers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "master_alive_workers{job=\"spark-master\"}",
        "legendFormat": "Alive", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 2,
      "title": "Cores (Used / Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 2 },
            { "color": "red", "value": 3 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "master_cores_used{job=\"spark-master\"}",
        "legendFormat": "Used", "interval": "", "exemplar": true
      }, {
        "expr": "master_cores{job=\"spark-master\"}",
        "legendFormat": "Total", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 3,
      "title": "Memory (Used / Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
