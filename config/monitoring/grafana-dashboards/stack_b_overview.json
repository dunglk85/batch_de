      "targets": [{
        "expr": "spark_Executor_Memory_Value", "legendFormat": "Memory", "interval": "", "exemplar": true
      }, {
        "expr": "spark_Executor_TotalCores_Count", "legendFormat": "Cores", "interval": "", "exemplar": true
      }]
    },
