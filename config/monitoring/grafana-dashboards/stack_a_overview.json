{
  "title": "Stack A – DWH Pipeline Overview",
  "uid": "stack_a_overview",
  "tags": ["dataops", "dwh", "stack-a", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "DAG Run Duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 120 },
            { "color": "red", "value": 300 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_dagrun_duration_seconds_sum{dag_id=\"duration\", status=\"success\"} / airflow_dagrun_duration_seconds_count{dag_id=\"duration\", status=\"success\"}",
        "legendFormat": "Avg Duration", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 2,
      "title": "Operator Failures",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "sum(airflow_ti_finish{status=~\".*failed.*\"})",
        "legendFormat": "Failed Tasks", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 3,
      "title": "Schedule Delay",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 300 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_dagrun_schedule_delay_sum / airflow_dagrun_schedule_delay_count",
        "legendFormat": "Avg Delay", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 4,
      "title": "Scheduler Heartbeat",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_scheduler_heartbeat",
        "legendFormat": "Heartbeat", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 5,
      "title": "Executor Slots",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_executor_open_slots", "legendFormat": "Open", "interval": "", "exemplar": true
      }, {
        "expr": "airflow_executor_running_tasks", "legendFormat": "Running", "interval": "", "exemplar": true
      }, {
        "expr": "airflow_executor_queued_tasks", "legendFormat": "Queued", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 6,
      "title": "DAG Run Duration Over Time",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_dagrun_duration_seconds_sum / airflow_dagrun_duration_seconds_count",
        "legendFormat": "Avg Duration", "interval": "", "exemplar": true
      }, {
        "expr": "airflow_dagrun_schedule_delay_sum / airflow_dagrun_schedule_delay_count",
        "legendFormat": "Schedule Delay", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 7,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "(sum(rate(pg_stat_database_blks_hit[5m])) / (sum(rate(pg_stat_database_blks_hit[5m])) + sum(rate(pg_stat_database_blks_read[5m])))) * 100",
        "legendFormat": "Cache Hit %", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 8,
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "pg_stat_activity_count", "legendFormat": "Total Connections", "interval": "", "exemplar": true
      }, {
        "expr": "pg_stat_database_numbackends", "legendFormat": "Backends", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 9,
      "title": "Database Size",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "pg_database_size_bytes", "legendFormat": "Size", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 10,
      "title": "Deadlocks, Commits & Rollbacks",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "rate(pg_stat_database_deadlocks[5m])", "legendFormat": "Deadlocks/s", "interval": "", "exemplar": true
      }, {
        "expr": "rate(pg_stat_database_xact_rollback[5m])", "legendFormat": "Rollbacks/s", "interval": "", "exemplar": true
      }, {
        "expr": "rate(pg_stat_database_xact_commit[5m])", "legendFormat": "Commits/s", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 11,
      "title": "Container CPU (top 5)",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "minVizWidth": 0, "minVizHeight": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 80 }
          ]},
          "custom": { "displayMode": "gradient" }
        }, "overrides": []
      },
      "targets": [{
        "expr": "topk(5, rate(container_cpu_usage_seconds_total{cpu=\"total\", id!=\"/\", id!=\"/docker\"}[1m]) * 100)",
        "legendFormat": "{{id}}", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 12,
      "title": "Container Memory (top 5)",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "minVizWidth": 0, "minVizHeight": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 524288000 },
            { "color": "red", "value": 1073741824 }
          ]},
          "custom": { "displayMode": "gradient" }
        }, "overrides": []
      },
      "targets": [{
        "expr": "topk(5, container_memory_working_set_bytes{id!=\"/\", id!=\"/docker\"})",
        "legendFormat": "{{id}}", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 13,
      "title": "Container Network I/O (top 5)",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "minVizWidth": 0, "minVizHeight": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1048576 },
            { "color": "red", "value": 10485760 }
          ]},
          "custom": { "displayMode": "gradient" }
        }, "overrides": []
      },
      "targets": [{
        "expr": "topk(5, rate(container_network_receive_bytes_total{id!=\"/\", id!=\"/docker\"}[1m]))",
        "legendFormat": "RX {{id}}", "interval": "", "exemplar": true
      }]
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
