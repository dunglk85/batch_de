{
  "title": "Containers – DWH Stack A",
  "uid": "dwh_containers",
  "tags": ["dataops", "dwh", "containers", "infra"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage (top 10 containers)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "minVizWidth": 0, "minVizHeight": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 80 }
          ]},
          "custom": { "displayMode": "gradient" }
        }, "overrides": []
      },
      "targets": [{
        "expr": "topk(10, rate(container_cpu_usage_seconds_total{cpu=\"total\", id!=\"/\", id!=\"/docker\"}[1m]) * 100)",
        "legendFormat": "{{id}}", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 2,
      "title": "Memory Usage (top 10 containers)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "minVizWidth": 0, "minVizHeight": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 524288000 },
            { "color": "red", "value": 1073741824 }
          ]},
          "custom": { "displayMode": "gradient" }
        }, "overrides": []
      },
      "targets": [{
        "expr": "topk(10, container_memory_working_set_bytes{id!=\"/\", id!=\"/docker\"})",
        "legendFormat": "{{id}}", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 3,
      "title": "CPU Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "rate(container_cpu_usage_seconds_total{cpu=\"total\", id!=\"/\", id!=\"/docker\"}[1m]) * 100",
        "legendFormat": "{{id}}", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 4,
      "title": "Memory Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "container_memory_working_set_bytes{id!=\"/\", id!=\"/docker\"}",
        "legendFormat": "{{id}}", "interval": "", "exemplar": true
      }]
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
