{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "description": "", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus" }
  ],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "title": "DWH Pipeline – Stack A",
  "uid": "dwh_pipeline_stack_a",
  "tags": ["dataops", "dwh", "airflow"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Last DAG Run Duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 120 },
            { "color": "red", "value": 300 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_dagrun_duration_seconds_sum{dag_id=\"duration\", status=\"success\"} / airflow_dagrun_duration_seconds_count{dag_id=\"duration\", status=\"success\"}",
        "legendFormat": "Avg Duration", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 2,
      "title": "DAG Runs (success)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "graphMode": "none", "colorMode": "background", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_dagrun_duration_seconds_count{dag_id=\"duration\", status=\"success\"}",
        "legendFormat": "Total Runs", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 3,
      "title": "Schedule Delay",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 300 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_dagrun_schedule_delay_sum / airflow_dagrun_schedule_delay_count",
        "legendFormat": "Avg Delay", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 4,
      "title": "Operator Failures",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "sum(airflow_ti_finish{ecommerce_dwh_stack_a_pipeline=~\".*failed.*\"})",
        "legendFormat": "Failed Tasks", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 5,
      "title": "Scheduler Heartbeat",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_scheduler_heartbeat",
        "legendFormat": "Heartbeat", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 6,
      "title": "DAG Processing Time",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 10 }
          ]}
        }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_dag_processing_last_duration",
        "legendFormat": "Last Parse", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 7,
      "title": "DAG Run Duration Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_dagrun_duration_seconds_sum{dag_id=\"duration\", status=\"success\"} / airflow_dagrun_duration_seconds_count{dag_id=\"duration\", status=\"success\"}",
        "legendFormat": "Avg Duration", "interval": "", "exemplar": true
      }, {
        "expr": "airflow_dagrun_schedule_delay_sum / airflow_dagrun_schedule_delay_count",
        "legendFormat": "Schedule Delay", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 8,
      "title": "Executor Slots",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_executor_open_slots", "legendFormat": "Open Slots", "interval": "", "exemplar": true
      }, {
        "expr": "airflow_executor_running_tasks", "legendFormat": "Running Tasks", "interval": "", "exemplar": true
      }, {
        "expr": "airflow_executor_queued_tasks", "legendFormat": "Queued Tasks", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 9,
      "title": "Pool Slots (default_pool)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_pool_open_slots_default_pool", "legendFormat": "Open", "interval": "", "exemplar": true
      }, {
        "expr": "airflow_pool_running_slots_default_pool", "legendFormat": "Running", "interval": "", "exemplar": true
      }, {
        "expr": "airflow_pool_queued_slots_default_pool", "legendFormat": "Queued", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 10,
      "title": "DAG Processing Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_dag_processing_total_parse_time", "legendFormat": "Total Parse Time", "interval": "", "exemplar": true
      }, {
        "expr": "airflow_dag_processing_last_duration", "legendFormat": "Last Duration", "interval": "", "exemplar": true
      }]
    },
    {
      "id": 11,
      "title": "Task Duration – Silver Transformation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "legend": { "calcs": ["min", "max", "avg"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0, "custom": { "showPoints": "auto", "spanNulls": false } }, "overrides": []
      },
      "targets": [{
        "expr": "airflow_dag_ecommerce_dwh_stack_a_pipeline_silver_transformation_transform_customers_duration_sum / airflow_dag_ecommerce_dwh_stack_a_pipeline_silver_transformation_transform_customers_duration_count",
        "legendFormat": "Customers", "interval": "", "exemplar": true
      }, {
        "expr": "airflow_dag_ecommerce_dwh_stack_a_pipeline_silver_transformation_transform_products_duration_sum / airflow_dag_ecommerce_dwh_stack_a_pipeline_silver_transformation_transform_products_duration_count",
        "legendFormat": "Products", "interval": "", "exemplar": true
      }, {
        "expr": "airflow_dag_ecommerce_dwh_stack_a_pipeline_silver_transformation_transform_transactions_duration_sum / airflow_dag_ecommerce_dwh_stack_a_pipeline_silver_transformation_transform_transactions_duration_count",
        "legendFormat": "Transactions", "interval": "", "exemplar": true
      }]
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
